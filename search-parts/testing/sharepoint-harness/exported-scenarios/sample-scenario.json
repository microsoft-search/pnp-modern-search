{
  "auth": {
    "tenantUrl": "https://tcwlv.sharepoint.com",
    "clientId": "00000000-0000-0000-0000-000000000000"
  },
  "site": {
    "url": "https://tcwlv.sharepoint.com/sites/pnp-search-harness-dev",
    "title": "PnP Modern Search Harness",
    "type": "CommunicationSite",
    "description": "Isolated site for provisioning web part validation"
  },
  "package": {
    "path": "../../sharepoint/solution/pnp-modern-search-parts-v4.sppkg",
    "skipFeatureDeployment": true
  },
  "pages": [
    {
      "name": "SearchValidation.aspx",
      "title": "Search Validation",
      "publish": true,
      "sections": [
        {
          "template": "OneColumn",
          "order": 1
        },
        {
          "template": "TwoColumn",
          "order": 2
        }
      ],
      "webParts": [
        {
          "componentKey": "search-box",
          "section": 1,
          "column": 1,
          "order": 1,
          "propertiesJson": {
            "placeholderText": "Search documents",
            "searchInNewTab": false,
            "enableQuerySuggestions": true
          }
        },
        {
          "componentKey": "search-filters",
          "section": 2,
          "column": 1,
          "order": 1,
          "propertiesJson": {
            "filters": []
          }
        },
        {
          "componentKey": "search-results",
          "section": 2,
          "column": 2,
          "order": 1,
          "propertiesJson": {
            "queryTemplate": "{searchTerms} Path:https://tcwlv.sharepoint.com/*",
            "selectedLayout": "documents",
            "showBlank": false
          }
        }
      ]
    }
  ]
}