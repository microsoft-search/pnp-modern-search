                  "maxWidth": "180",
                  "enableSorting": false,
                  "isMultiline": false,
                  "isResizable": true,
                  "sortIdx": 1
                },
                {
                  "name": "Review date",
                  "value": "<span style= \"color: black\">\n    {{getDate (slot item @root.slots.Date)  'LL'}}\n</span>\n",
                  "useHandlebarsExpr": true,
                  "minWidth": "80",
                  "maxWidth": "110",
                  "enableSorting": true,
