                  "valueSorting": "RefinableDate05"
                },
                {
                  "uniqueId": "dcee1650-bbed-4633-a908-b5407d198631",
                  "name": "Days to review",
                  "value": "{{#with (dayDiff (getDate (moment) 'YYYY-MMM-DD') (getDate (slot item @root.slots.Date) 'YYYY-MMM-DD')) as |daysSinceLastReview|}}\r\n{{#with (slot item @root.slots.ReviewInteval) as |reviewInterval|}}\r\n\r\n{{#compare reviewInterval \"==\" \"1 month\"}}\r\n    {{#compare daysSinceLastReview \"==\" 30}}\r\n        <span style=\"background-color: yellow\">Due TODAY</span>\r\n    {{else}}\r\n        {{#compare daysSinceLastReview \">\" 30}}\r\n            <span style=\"color: red\">Overdue<br>(interval 30 days, elapsed {{daysSinceLastReview}} days)</span>\r\n        {{else}}\r\n            <span style=\"color: green\">Not due yet<br>(interval 30 days, elapsed {{daysSinceLastReview}} days)</span>\r\n        {{/compare}}\r\n    {{/compare}}\r\n{{else}}\r\n\r\n{{#compare reviewInterval \"==\" \"3 months\"}}\r\n    {{#compare daysSinceLastReview \"==\" 90}}\r\n        <span style=\"background-color: yellow\">Due TODAY</span>\r\n    {{else}}\r\n        {{#compare daysSinceLastReview \">\" 90}}\r\n            <span style=\"color: red\">Overdue<br>(interval 90 days, elapsed {{daysSinceLastReview}} days)</span>\r\n        {{else}}\r\n            <span style=\"color: green\">Not due yet<br>(interval 90 days, elapsed {{daysSinceLastReview}} days)</span>\r\n        {{/compare}}\r\n    {{/compare}}\r\n{{else}}\r\n\r\n{{#compare reviewInterval \"==\" \"6 months\"}}\r\n    {{#compare daysSinceLastReview \"==\" 180}}\r\n        <span style=\"background-color: yellow\">Due TODAY</span>\r\n    {{else}}\r\n        {{#compare daysSinceLastReview \">\" 180}}\r\n            <span style=\"color: red\">Overdue<br>(interval 180 days, elapsed {{daysSinceLastReview}} days)</span>\r\n        {{else}}\r\n            <span style=\"color: green\">Not due yet<br>(interval 180 days, elapsed {{daysSinceLastReview}} days)</span>\r\n        {{/compare}}\r\n    {{/compare}}\r\n{{else}}\r\n\r\n{{#compare reviewInterval \"==\" \"12 months\"}}\r\n    {{#compare daysSinceLastReview \"==\" 365}}\r\n        <span style=\"background-color: yellow\">Due TODAY</span>\r\n    {{else}}\r\n        {{#compare daysSinceLastReview \">\" 365}}\r\n            <span style=\"color: red\">Overdue<br>(interval 365 days, elapsed {{daysSinceLastReview}} days)</span>\r\n        {{else}}\r\n            <span style=\"color: green\">Not due yet<br>(interval 365 days, elapsed {{daysSinceLastReview}} days)</span>\r\n        {{/compare}}\r\n    {{/compare}}\r\n{{else}}\r\n\r\n{{#compare reviewInterval \"==\" \"24 months\"}}\r\n    {{#compare daysSinceLastReview \"==\" 730}}\r\n        <span style=\"background-color: yellow\">Due TODAY</span>\r\n    {{else}}\r\n        {{#compare daysSinceLastReview \">\" 730}}\r\n            <span style=\"color: red\">Overdue<br>(interval 730 days, elapsed {{daysSinceLastReview}} days)</span>\r\n        {{else}}\r\n            <span style=\"color: green\">Not due yet<br>(interval 730 days, elapsed {{daysSinceLastReview}} days)</span>\r\n        {{/compare}}\r\n    {{/compare}}\r\n{{else}}\r\n    <span style=\"color: #b45309\">Unknown review interval value: {{reviewInterval}}</span>\r\n{{/compare}}\r\n\r\n{{/compare}}\r\n\r\n{{/compare}}\r\n\r\n{{/compare}}\r\n\r\n{{/compare}}\r\n\r\n{{/with}}\r\n{{/with}}",
